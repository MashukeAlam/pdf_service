<div style="
  min-height: 100vh;
  padding: 0;
">

  <div style="
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding-top: 70px;
  ">
    <div class="container" style="
      background: rgba(255,255,255,0.97);
      border-radius: 24px;
      box-shadow: 0 8px 40px rgba(37,99,235,0.10);
      padding: 60px 40px 40px 40px;
      max-width: 600px;
      width: 100%;
      text-align: center;
    ">
      <h1 style="font-size:3rem; color:#2563eb; margin-bottom: 0.5em; letter-spacing: -2px; font-weight: 800;">PDF Service</h1>
      <p style="font-size:1.3rem; color:#374151; margin-bottom: 2em;">Create, manage, and generate beautiful PDFs from dynamic templates.</p>
      <div style="display:flex; justify-content:center; gap:32px; flex-wrap:wrap; margin-bottom:2em;">
        <a href="<%= templates_path %>" class="link" style="font-size:1.2rem; background:#2563eb; color:#fff; padding:18px 36px; border-radius:10px; text-decoration:none; box-shadow:0 2px 12px rgba(37,99,235,0.08); font-weight:600;">Manage Templates</a>
        <a href="<%= pdfs_path %>" class="link" style="font-size:1.2rem; background:#10b981; color:#fff; padding:18px 36px; border-radius:10px; text-decoration:none; box-shadow:0 2px 12px rgba(16,185,129,0.08); font-weight:600;">View Generated PDFs</a>
        <a href="<%= new_pdf_path %>" class="link" style="font-size:1.2rem; background:#f59e42; color:#fff; padding:18px 36px; border-radius:10px; text-decoration:none; box-shadow:0 2px 12px rgba(245,158,66,0.08); font-weight:600;">Generate New PDF</a>
      </div>
      <div style="margin-top:3em;"></div>
    </div>
  </div>
</div>
