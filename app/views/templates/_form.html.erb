<div>
<%= form_with(model: template, local: true) do |form| %>
  <% if template.errors.any? %>
    <div class="alert">
      <h2><%= pluralize(template.errors.count, "error") %> prohibited this template from being saved:</h2>
      <ul>
        <% template.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name %>
    <%= form.text_field :name %>
  </div>

  <div>
    <%= form.label :signature %>
    <%= form.text_area :signature, value: template.signature.to_json, rows: 8 %>
    <small>Enter valid JSON for the signature.</small>
  </div>

  <div>
    <%= form.label :content, "ERB Content" %>
    <%= form.text_area :content, rows: 12 %>
    <small>Use ERB syntax. Example: &lt;%= data["key"] %&gt;</small>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
</div>
